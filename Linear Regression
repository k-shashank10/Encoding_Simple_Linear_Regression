import pandas as pd
import matplotlib.pyplot as plt
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import OrdinalEncoder
from sklearn.linear_model import LinearRegression

# Task 1: Create DataFrame
data = {
    "review": ["poor", "average", "good", "poor", "good", "average"],
    "cgpa": [6.5, 7.2, 8.1, 5.9, 8.5, 7.0],
    "package": [3.0, 4.2, 6.0, 2.8, 6.5, 4.0]
}

df = pd.DataFrame(data)

# Apply OrdinalEncoder to review column
encoder = OrdinalEncoder(categories=[["poor", "average", "good"]])
df["review_encoded"] = encoder.fit_transform(df[["review"]])

# Split data into train and test sets
X = df[["cgpa"]]   
y = df["package"]

X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)

# Task 2: Train Linear Regression model
model = LinearRegression()
model.fit(X_train, y_train)

# Predict on test set
y_pred = model.predict(X_test)

# Print slope, intercept, and predictions
print("Slope (Coefficient):", model.coef_[0])
print("Intercept:", model.intercept_)
print("Predicted values:", y_pred)

#Plot actual vs predicted
plt.scatter(X_test, y_test, color="blue", label="Actual values")
plt.plot(X_test, y_pred, color="red", linewidth=2, label="Predicted line")
plt.xlabel("CGPA")
plt.ylabel("Package")
plt.title("Linear Regression: CGPA vs Package")
plt.legend()
plt.show()
